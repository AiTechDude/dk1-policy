# Reusable GitHub Actions workflow for Graphify CI freshness checks.
# Copy to .github/workflows/graphify-check.yml in any Graphified DK1 repo.
# See ~/Projects/dk1-policy/standards/graphify-adoption.md §6.
#
# Behavior:
#   - On every PR touching code/docs: rebuild graph (AST + semantic), upload
#     GRAPH_REPORT.md as an artifact, post a diff comment if the report changed.
#     Advisory only — never fails the build.
#   - Weekly Monday 6 AM UTC: rebuild against main and commit graphify-out/cache/
#     only (graph itself stays out of git per DK1 Rule 4).
#
# Required repo secrets:
#   ANTHROPIC_API_KEY  — used by `--backend claude` semantic extraction.

name: graphify-check

on:
  pull_request:
    paths:
      - '**.py'
      - '**.ts'
      - '**.tsx'
      - '**.js'
      - '**.jsx'
      - '**.sql'
      - '**.yaml'
      - '**.yml'
      - 'docs/**.md'
      - 'README.md'
      - 'CLAUDE.md'
      - 'AGENTS.md'
  schedule:
    # Monday 6 AM UTC == ~1-2 AM ET depending on DST; aligns with dk1-infrawatch
    - cron: '0 6 * * 1'
  workflow_dispatch:

permissions:
  contents: read
  pull-requests: write

jobs:
  graphify:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Install uv
        run: |
          curl -LsSf https://astral.sh/uv/install.sh | sh
          echo "$HOME/.local/bin" >> "$GITHUB_PATH"

      - name: Install graphifyy + anthropic
        run: |
          uv tool install graphifyy
          uv tool install graphifyy --with anthropic --force
          graphify --version

      - name: Build graph (advisory)
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: |
          if [[ -z "$ANTHROPIC_API_KEY" ]]; then
            echo "::warning::ANTHROPIC_API_KEY secret not set; running AST-only update"
            # If a previous run cached the graph in artifacts we could pull it; for now bail to AST.
            graphify update . || true
          else
            graphify extract . --backend claude --max-concurrency 2 --no-cluster || true
            graphify cluster-only . --no-viz || true
          fi

      - name: Upload graph artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: graphify-out
          path: |
            graphify-out/GRAPH_REPORT.md
            graphify-out/graph.json
            graphify-out/.graphify_analysis.json
          retention-days: 14

      - name: Diff GRAPH_REPORT.md against main (PR only)
        if: github.event_name == 'pull_request'
        run: |
          set +e
          MAIN_REPORT=$(mktemp)
          git show "origin/${{ github.base_ref }}:graphify-out/GRAPH_REPORT.md" > "$MAIN_REPORT" 2>/dev/null || echo "(no prior report on base)" > "$MAIN_REPORT"
          diff -u "$MAIN_REPORT" graphify-out/GRAPH_REPORT.md > graphify-out/REPORT_DIFF.patch || true
          if [[ -s graphify-out/REPORT_DIFF.patch ]]; then
            echo "### Graphify report diff" >> "$GITHUB_STEP_SUMMARY"
            echo '```diff' >> "$GITHUB_STEP_SUMMARY"
            head -c 8000 graphify-out/REPORT_DIFF.patch >> "$GITHUB_STEP_SUMMARY"
            echo '```' >> "$GITHUB_STEP_SUMMARY"
          else
            echo "No structural changes detected in GRAPH_REPORT.md." >> "$GITHUB_STEP_SUMMARY"
          fi

      - name: Comment on PR with summary link
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            let body = '### graphify-check (advisory)\n\n';
            try {
              const diff = fs.readFileSync('graphify-out/REPORT_DIFF.patch', 'utf8');
              if (diff && diff.trim().length > 0) {
                const truncated = diff.length > 8000 ? diff.slice(0, 8000) + '\n... (truncated; see workflow Summary)' : diff;
                body += '<details><summary>GRAPH_REPORT.md diff</summary>\n\n```diff\n' + truncated + '\n```\n\n</details>';
              } else {
                body += 'No structural changes detected.';
              }
            } catch (e) {
              body += '_No diff produced (likely no prior graph on base branch)._';
            }
            body += '\n\nFull artifacts uploaded to this workflow run.';
            await github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
              body
            });

      - name: Never fail the build
        run: 'true'
